# MindCare Environment Configuration
# Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
DATABASE_URL=sqlite:///mood_data.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Frontend Configuration
FRONTEND_URL=http://localhost:8000

# ML Models
USE_GPU=False
MODEL_PATH=./models/

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Data Storage
ENABLE_DATA_PERSISTENCE=True
DATA_RETENTION_DAYS=90

# Email (for future features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# External APIs (optional)
# GOOGLE_API_KEY=your-google-api-key
# MICROSOFT_API_KEY=your-microsoft-api-key

# Feature Flags
ENABLE_CHATBOT=True
ENABLE_VOICE_ANALYSIS=True
ENABLE_FACIAL_DETECTION=True
ENABLE_MOOD_DASHBOARD=True

# Security
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT=1800
MAX_LOGIN_ATTEMPTS=5

# Performance
MAX_FILE_SIZE=5242880
CACHE_TIMEOUT=300
